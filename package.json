{
  "name": "gresmalt-ghg-tool",
  "version": "1.0.0",
  "description": "GHG Tool — Sustainability platform per Gruppo Ceramiche Gresmalt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && python3 -m http.server --directory site 8000",
    "test": "node test/index.mjs",
    "test:e2e": "playwright test",
    "lint": "eslint --ext .js,.jsx,.mjs --max-warnings 50 src/ test/ build.mjs",
    "lint:no-dangerous-html": "! grep -r --include='*.jsx' --include='*.js' 'dangerouslySetInnerHTML' src/"
  },
  "dependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@e965/xlsx": "0.20.3",
    "@supabase/supabase-js": "2.105.4",
    "chart.js": "4.5.1",
    "pptxgenjs": "4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "8.57.1"
  },
  "comment-pinning": "Le versioni sono pinnate (no caret) per garantire build riproducibili e per il calcolo deterministico degli SRI hash. ESLint 8.57.x è l'ultima LTS che supporta il legacy .eslintrc.json (la 9.x usa flat config).",
  "engines": {
    "node": ">=18.0.0"
  }
}
